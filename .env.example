POSTGRES_USER=dev
POSTGRES_PASSWORD=dev01
POSTGRES_DB=dots-beacon-dev
DATABASE_URL=postgresql://dev:dev01@localhost:5432/dots-beacon-dev?sslmode=disable

# # App
# APP_ENV=dev
# HTTP_PORT=8080

# # OpenTelemetry (per service: set OTEL_SERVICE_NAME; share the endpoint).
# # Use http://localhost:4317 for host-run services, http://otel-collector:4317
# # from inside docker compose.
# OTEL_SERVICE_NAME=api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# # MinIO (S3-compatible object storage) — backs Tempo traces + Loki logs.
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=
# TEMPO_S3_BUCKET=tempo
# LOKI_S3_BUCKET=loki

# Keycloak (OIDC)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Resource-server token validation — leave KEYCLOAK_ISSUER_URL empty to disable.
# Issuer is the realm URL, e.g. http://localhost:8081/realms/dots-beacon
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLIENT_ID=
