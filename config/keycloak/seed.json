{
  "realm": "dots-beacon",
  "enabled": true,
  "displayName": "dots-beacon",
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "dots-beacon-app",
      "name": "dots-beacon SPA (browser)",
      "description": "Public client for the React single-page app. Uses the authorization-code flow with PKCE; no client secret.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "redirectUris": ["http://localhost:5173/*", "http://localhost:8080/*", "http://localhost:4200/*", "http://127.0.0.1:4200/*"],
      "webOrigins": ["+","http://localhost:5173"],
      "defaultClientScopes": ["dots-beacon-api-audience"],
      "attributes": {
        "post.logout.redirect.uris": "+",
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "dots-beacon-m2m",
      "name": "dots-beacon machine-to-machine",
      "description": "Confidential client for server-to-server / worker-to-server authentication via the client-credentials grant (service account).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "I>ShD>dR)3@)4ZnR--EKgN:oaC,fyR-)rY$VIeJ:HOy",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": false,
      "defaultClientScopes": ["dots-beacon-api-audience"]
    }
  ],

  "clientScopes": [
    {
      "name": "dots-beacon-api-audience",
      "description": "Adds the dots-beacon-api audience to access tokens so the API (resource server) accepts tokens from any client carrying this scope.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "dots-beacon-api audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "dots-beacon-api",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],

  "defaultDefaultClientScopes": ["dots-beacon-api-audience"],

  "users": [
    {
      "username": "god",
      "enabled": true,
      "emailVerified": true,
      "email": "god@dots-beacon.local",
      "firstName": "Site",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "m+Bm3D+ir*>_r#%+hqA,",
          "temporary": true
        }
      ]
    },
    {
      "username": "service-account-dots-beacon-m2m",
      "enabled": true,
      "serviceAccountClientId": "dots-beacon-m2m",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users"]
      }
    }
  ]
}
