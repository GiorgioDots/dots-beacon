      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "redirectUris": ["http://localhost:5173/*", "http://localhost:8080/*", "http://localhost:4200/*", "http://127.0.0.1:4200/*"],
      "webOrigins": ["+","http://localhost:5173"],
      "attributes": {
        "post.logout.redirect.uris": "+",
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "dots-beacon-m2m",
      "name": "dots-beacon machine-to-machine",
      "description": "Confidential client for server-to-server / worker-to-server authentication via the client-credentials grant (service account).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "I>ShD>dR)3@)4ZnR--EKgN:oaC,fyR-)rY$VIeJ:HOy",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": false
    }
  ],

  "users": [
    {
      "username": "god",
      "enabled": true,
      "emailVerified": true,
      "email": "god@dots-beacon.local",
      "firstName": "Site",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "m+Bm3D+ir*>_r#%+hqA,",
          "temporary": true
        }
      ]
    },
    {
      "username": "service-account-dots-beacon-m2m",
      "enabled": true,
      "serviceAccountClientId": "dots-beacon-m2m",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users"]
      }
    }
  ]
}
